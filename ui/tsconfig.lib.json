{
  "compilerOptions": {
    "target": "es2023",
    "ignoreDeprecations": "6.0",
    "lib": ["ES2023", "DOM", "DOM.Iterable"],
    "module": "esnext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "skipLibCheck": true,
    "strict": false,
    "noEmit": false,
    "declaration": true,
    "emitDeclarationOnly": true,
    "allowImportingTsExtensions": false
  },
  "include": ["src/index.ts"]
}
