{
  "name": "@lumvale/pdf-ui",
  "author": {
    "name": "Lumvale",
    "email": "amir@lumvale.com"
  },
  "homepage": "https://github.com/Lumvale/lumvale-pdf",
  "description": "LumvalePDF desktop application and embeddable workspace UI library",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/Lumvale/lumvale-pdf.git",
    "directory": "ui"
  },
  "private": false,
  "version": "0.4.0",
  "type": "module",
  "sideEffects": [
    "**/*.css"
  ],
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./styles.css": "./src/index.css",
    "./fx.css": "./src/fx.css"
  },
  "files": [
    "dist",
    "src/index.css",
    "src/fx.css"
  ],
  "scripts": {
    "build:worker": "node scripts/build-worker.mjs",
    "dev": "npm run build:worker && vite --force",
    "dev:web": "set BUILD_TARGET=web&& npm run build:worker && vite --force",
    "start": "electron .",
    "build": "npm run build:worker && tsc -b && vite build",
    "build:lib": "npm run build:worker && tsup",
    "prepack": "npm run build:worker && tsup",
    "build:web": "set BUILD_TARGET=web&& npm run build:worker && tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:ui": "playwright test --ui"
  },
  "dependencies": {
    "@hello-pangea/dnd": "^18.0.1",
    "@huggingface/transformers": "^4.2.0",
    "@lumvale/pdf-browser": "^0.1.0",
    "@lumvale/pdf-core": "^1.2.0",
    "@types/jszip": "^3.4.0",
    "docx": "^9.7.1",
    "electron-squirrel-startup": "^1.0.1",
    "electron-updater": "^6.8.9",
    "framer-motion": "^12.40.0",
    "idb-keyval": "^6.2.5",
    "jszip": "^3.10.1",
    "lodash": "^4.18.1",
    "lucide-react": "^1.18.0",
    "mammoth": "^1.12.0",
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^6.0.227",
    "react-markdown": "^10.1.0",
    "tesseract.js": "^7.0.0"
  },
  "peerDependencies": {
    "react": ">=19",
    "react-dom": ">=19"
  },
  "main": "dist-electron/main.js",
  "devDependencies": {
    "react": "^19.0.0-rc.1",
    "react-dom": "^19.0.0-rc.1",
    "tsup": "^8.5.0",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/vite": "^4.3.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.12.3",
    "@types/pdfjs-dist": "^2.10.377",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^1.6.1",
    "electron": "^34.2.0",
    "electron-builder": "^25.0.5",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "tailwindcss": "^4.3.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12",
    "vite-plugin-electron": "^0.29.0",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^1.6.1"
  },
  "build": {
    "appId": "com.vaultos.lumvalepdf",
    "productName": "LumvalePDF",
    "directories": {
      "output": "release/${version}"
    },
    "win": {
      "target": [
        "nsis"
      ]
    },
    "mac": {
      "target": {
        "target": "dmg",
        "arch": [
          "universal"
        ]
      }
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Office"
    },
    "fileAssociations": [
      {
        "ext": "pdf",
        "name": "PDF Document",
        "description": "LumvalePDF Document",
        "role": "Viewer"
      }
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "vaultos",
        "repo": "lumvalepdf"
      }
    ]
  }
}
