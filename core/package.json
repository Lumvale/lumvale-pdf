{
  "name": "@lumvalepdf/core",
  "version": "1.0.0",
  "description": "The WebAssembly-powered PDF engine for LumvalePDF",
  "license": "Apache-2.0",
  "homepage": "https://github.com/Lumvale/lumvale-pdf",
  "repository": {
    "type": "git",
    "url": "https://github.com/Lumvale/lumvale-pdf.git",
    "directory": "core"
  },
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "test": "vitest run",
    "prepack": "npm run build"
  },
  "dependencies": {
    "@pdfsmaller/pdf-encrypt-lite": "^1.0.2",
    "pdf-lib": "^1.17.1"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "vitest": "^1.0.0"
  }
}
